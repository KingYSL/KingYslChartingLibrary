<UserControl x:Class="ChartingLibrary1._4.View.UserControls.Chart"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ChartingLibrary1._4.View.UserControls"
             xmlns:local1="clr-namespace:ChartingLibrary1._4.Models" xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <local1:Plot  DataContext="{Binding ChartCanvas}"  Background="WhiteSmoke" Cursor="Cross">
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="MouseWheel">
                    <i:InvokeCommandAction Command="{Binding DataContext.ZoomChartCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                       PassEventArgsToCommand="True" />
                </i:EventTrigger>
            </i:Interaction.Triggers>
                
                </local1:Plot>
    </Grid>
</UserControl>
    
    


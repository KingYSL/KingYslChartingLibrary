<UserControl x:Class="ChartingLibrary1._4.View.UserControls.ChartControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ChartingLibrary1._4.View.UserControls" xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*" />
            <RowDefinition Height="10*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="10*"/>
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>


        <ContentPresenter x:Name="ChartPlot" Grid.Column="1" Grid.Row="1" Content="{Binding PlotControl.ChartingArea}">
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="MouseWheel">
                    <i:InvokeCommandAction Command="{Binding PlotControl.ZoomChartCommand}" 
                PassEventArgsToCommand="True" />
                </i:EventTrigger>
            </i:Interaction.Triggers>
        </ContentPresenter>

        <ContentPresenter x:Name="TopPanel" Visibility="{Binding PlotControl.ShowTopPanel, Converter={StaticResource BoolToVisibilityConverter}}" Content="{Binding PlotControl.WAxis}"  
                      Grid.Row="0" Grid.Column="1">
    
        </ContentPresenter>
   <ContentPresenter x:Name="BottomPanel" Visibility="{Binding PlotControl.ShowBottomPanel, Converter={StaticResource BoolToVisibilityConverter}}" Content="{Binding PlotControl.XAxis}"
                      Grid.Row="2" Grid.Column="1"/>

        <ContentPresenter x:Name="RightPanel" Visibility="{Binding PlotControl.ShowRightPanel,
                                     Converter={StaticResource BoolToVisibilityConverter}}" Content="{Binding PlotControl.YAxis}"
                      Grid.Row="1" Grid.Column="2"/>

     
        <ContentPresenter x:Name="LeftPanel" Visibility="{Binding PlotControl.ShowLeftPanel, Converter={StaticResource BoolToVisibilityConverter}}" Content="{Binding PlotControl.ZAxis}"
                      Grid.Row="1" Grid.Column="0"/>


    </Grid>
</UserControl>

